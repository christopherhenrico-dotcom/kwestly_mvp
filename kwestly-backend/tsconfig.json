{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "checkJs": true,
    "allowJs": true,
    "lib": ["ES2022"]
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "pb_data", "dist", "payment_worker"]
}
